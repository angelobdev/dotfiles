{
  // *** LEFT MODULES *** //

  "hyprland/workspaces": {
    "format": "{windows}",
    "format-window-separator": " <span size=\"x-large\">|</span> ",
    "window-rewrite-default": "п†’",
    "window-rewrite": {
      "google-chrome": "п‰Ё",
      "thunar": "пЃј",
      "code": "<span size=\"large\">у°Ёћ</span>",
      "alacritty": "<span size=\"x-large\">оћ•</span>",
      "obsidian": "п†ќ",
      "spotify": "п†ј",
      "title<.*software.*>": "пЉђ",
      "easyeffects": "<span size=\"large\">п–Џ</span>",
      "discord": "пЋ’",
      "steam": "п†¶"
    }
  },

  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": true
    },
    "modules": ["temperature", "cpu", "memory"]
  },

  "cpu": {
    "interval": 5,
    "format": "п‹›  {}% ",
    "max-length": 10
  },

  "memory": {
    "interval": 5,
    "format": "п”ё {}%",
    "max-length": 10
  },

  "temperature": {
    "thermal-zone": 2,
    "format": "п‹‰ {temperatureC}В°C ",
    "tooltip": false
  },

  "custom/silent": {
    "format": "<span size=\"medium\">пѓі</span>",
    "format-alt": "<span size=\"medium\">п‡¶</span>",
    "tooltip": true,
    "tooltip-format": "Enable/Disable Notifications",
    "on-click": "exec ~/.config/hypr/scripts/NotifyToggle.sh"
  },

  "custom/lightdark": {
    "format": "<span size=\"medium\">п†…</span>",
    "format-alt": "<span size=\"medium\">п††</span>",
    "tooltip-format": "Enable/Disable Notifications",
    "on-click": "exec ~/.config/hypr/scripts/LightDarkModeSwitch.sh"
  },

  // *** RIGHT MODULES *** //

  "privacy": {
    "icon-spacing": 4,
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24
      }
    ]
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "п„і  {:%A, %B %d, %Y (%R)} ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  "systemd-failed-units": {
    "hide-on-ok": true, // Do not hide if there is zero failed units.
    "format": "пЃ± {nr_failed}",
    "system": true, // Monitor failed systemwide units.
    "user": true // Ignore failed user units.
  },

  "custom/spotify": {
    "exec": "/usr/bin/python3 ~/.config/waybar/scripts/MediaPlayer.py --player spotify",
    "format": "п†ј  {}",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },

  // *** RIGHT MODULES *** //

  "tray": {
    "icon-size": 14,
    "spacing": 6
  },

  "wireplumber": {
    "format": "{icon}    {volume}%",
    "format-muted": "пљ© Muted",
    "on-click": "~/.config/waybar/scripts/Switcher.sh",
    "format-icons": ["пЂ¦", "пЂ§", "пЂЁ"],
    "reverse-scrolling": 1
  },

  "upower": {
    "icon-size": 12,
    "format-alt": "{percentage}",
    "hide-if-empty": false,
    "tooltip": true,
    "tooltip-spacing": 16,
    "on-click": "tlpui"
  },

  "custom/powermenu": {
    "format": "<span size=\"large\">п‹ќ</span>",
    "tooltip": false,
    "on-click": "exec wlogout -b 5 -p layer-shell"
  }
}
